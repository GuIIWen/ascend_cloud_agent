### 13.7 жЈҖзҙўеўһејә

**ж”ҜжҢҒжқҘжәҗиҝҮж»Өзҡ„жЈҖзҙў**пјҡ
```java
public class HybridRetriever {
    
    /**
     * ж”ҜжҢҒжқҘжәҗзұ»еһӢиҝҮж»Өзҡ„жЈҖзҙў
     */
    public List<ApiMetadata> search(String query, int topK, SearchOptions options) {
        // 1. з”ҹжҲҗжҹҘиҜўеҗ‘йҮҸ
        float[] queryVector = embeddingService.embed(query);
        
        // 2. еҗ‘йҮҸжЈҖзҙўпјҲеҸ¬еӣһжӣҙеӨҡеҖҷйҖүпјү
        List<ApiMetadata> candidates = vectorStore.search(queryVector, topK * 3);
        
        // 3. жҢүжқҘжәҗзұ»еһӢиҝҮж»Ө
        if (options.getSourceTypes() != null) {
            candidates = candidates.stream()
                .filter(api -> options.getSourceTypes().contains(api.getSourceType()))
                .collect(Collectors.toList());
        }
        
        // 4. RerankйҮҚжҺ’еәҸ
        List<ApiMetadata> reranked = rerankService.rerank(query, candidates);
        
        // 5. иҝ”еӣһTop K
        return reranked.stream().limit(topK).collect(Collectors.toList());
    }
}

public class SearchOptions {
    private Set<DocumentSourceType> sourceTypes;  // жҢүжқҘжәҗзұ»еһӢиҝҮж»Ө
    private boolean includeInternal = true;       // еҢ…еҗ«еҶ…йғЁAPI
    private boolean includeExternal = true;       // еҢ…еҗ«еӨ–йғЁAPI
    private String serviceNameFilter;             // жҢүжңҚеҠЎеҗҚиҝҮж»Ө
}
```

**з»“жһңеұ•зӨәпјҲеёҰжқҘжәҗж ҮиҜҶпјү**пјҡ
