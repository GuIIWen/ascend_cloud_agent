### 13.4 ж–ҮжЎЈи§ЈжһҗеҷЁжһ¶жһ„

**ж ёеҝғжҺҘеҸЈ**пјҡ
```java
/**
 * ж–ҮжЎЈи§ЈжһҗеҷЁжҺҘеҸЈ - жҜҸз§Қж јејҸдёҖдёӘе®һзҺ°
 */
public interface DocumentParser {
    /**
     * жЈҖжҹҘжҳҜеҗҰж”ҜжҢҒиҜҘж–ҮжЎЈжәҗ
     */
    boolean supports(DocumentSource source);
    
    /**
     * и§Јжһҗж–ҮжЎЈе№¶жҸҗеҸ–еҺҹе§ӢAPIдҝЎжҒҜ
     */
    List<RawApiInfo> parse(DocumentSource source) throws ParseException;
}

/**
 * еҺҹе§ӢAPIдҝЎжҒҜпјҲи§ЈжһҗеҗҺгҖҒиҪ¬жҚўеүҚпјү
 */
public class RawApiInfo {
    private String name;
    private String description;
    private Map<String, Object> properties;    // ж јејҸзү№е®ҡзҡ„еұһжҖ§
}

/**
 * еӨ–йғЁAPIжҸҗеҸ–еҷЁ - е°ҶRawApiInfoиҪ¬жҚўдёәApiMetadata
 */
public interface ExternalApiExtractor {
    ApiMetadata extract(RawApiInfo rawInfo, DocumentSource source);
}
```

**OpenAPIи§ЈжһҗеҷЁзӨәдҫӢ**пјҡ
```java
public class OpenApiParser implements DocumentParser {
    
    @Override
    public boolean supports(DocumentSource source) {
        return source.getType() == DocumentSourceType.OPENAPI_FILE;
    }
    
    @Override
    public List<RawApiInfo> parse(DocumentSource source) {
        // дҪҝз”Ёswagger-parserеә“
        OpenAPI openAPI = new OpenAPIV3Parser().read(source.getLocation());
        
        List<RawApiInfo> apis = new ArrayList<>();
        
        // йҒҚеҺҶжүҖжңүи·Ҝеҫ„е’Ңж“ҚдҪң
        openAPI.getPaths().forEach((path, pathItem) -> {
            pathItem.readOperationsMap().forEach((method, operation) -> {
                RawApiInfo api = new RawApiInfo();
                api.setName(operation.getOperationId());
                api.setDescription(operation.getSummary() + " " + 
                                   operation.getDescription());
                
                Map<String, Object> props = new HashMap<>();
                props.put("httpMethod", method.name());
                props.put("endpoint", path);
                props.put("parameters", operation.getParameters());
                props.put("requestBody", operation.getRequestBody());
                props.put("responses", operation.getResponses());
                
                api.setProperties(props);
                apis.add(api);
            });
        });
        
        return apis;
    }
}
```

