server:
  port: ${SERVER_PORT:8080}

spring:
  application:
    name: ${SPRING_APPLICATION_NAME:ascend-agent}

management:
  endpoints:
    web:
      exposure:
        include: ${MANAGEMENT_ENDPOINTS_EXPOSURE_INCLUDE:health,info}
  endpoint:
    health:
      show-details: ${MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS:always}

logging:
  level:
    com.agent: ${LOGGING_LEVEL_COM_AGENT:INFO}
    dev.langchain4j: ${LOGGING_LEVEL_LANGCHAIN4J:DEBUG}

knowledge-base:
  # 向量存储配置
  vector-store:
    type: chroma  # chroma 或 milvus
    url: http://localhost:22333
    collection: api-knowledge-base

  # 嵌入模型配置
  embedding:
    provider: ${EMBEDDING_PROVIDER:local}  # local/custom
    api-url: ${EMBEDDING_API_URL:http://localhost:8080/v1/embeddings}
    api-key: ${EMBEDDING_API_KEY:}
    model: ${EMBEDDING_MODEL:bge-large-zh-v1.5}
    dimension: 1024
    timeout-seconds: ${EMBEDDING_TIMEOUT_SECONDS:30}

  # 重排序模型配置
  rerank:
    provider: ${RERANK_PROVIDER:none}
    api-url: ${RERANK_API_URL:http://localhost:8080/v1/rerank}
    api-key: ${RERANK_API_KEY:}
    model: ${RERANK_MODEL:bge-reranker-large}
    top-k: 5
    timeout-seconds: ${RERANK_TIMEOUT_SECONDS:30}

  # 大模型配置（Chat Completions）
  llm:
    provider: ${LLM_PROVIDER:none}
    api-url: ${LLM_API_URL:http://localhost:8080/v1/chat/completions}
    api-key: ${LLM_API_KEY:}
    model: ${LLM_MODEL:qwen-coder-plus}
    temperature: ${LLM_TEMPERATURE:0.2}
    max-tokens: ${LLM_MAX_TOKENS:4096}
    timeout-seconds: ${LLM_TIMEOUT_SECONDS:30}

  # 文档源配置
  sources:
    # Java项目
    - id: internal-code
      name: Internal Java Code
      type: INTERNAL_CODE
      location: ./src/main/java
      enabled: true

    # 网页文档示例
    - id: huawei-api-docs
      name: Huawei Cloud API Docs
      type: WEB_PAGE
      location: https://support.huaweicloud.com/api-modelarts/
      enabled: false
      refresh-interval: 86400  # 24小时
      metadata:
        crawl-depth: "2"
        rate-limit: "1"

    # Markdown文档示例
    - id: local-docs
      name: Local Documentation
      type: MARKDOWN_FILE
      location: ./docs/API.md
      enabled: false
